<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="Controllers.PrincipalController">

    <VBox spacing="15"
          style="-fx-padding: 15;"
          AnchorPane.topAnchor="0.0"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.rightAnchor="0.0">

        <HBox spacing="20">
            <Label text="PAINEL DE CONTROLE DE ESTOQUE"
                   style="-fx-font-size: 18; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="btnAtualizarDados" text="Atualizar"/>
        </HBox>

        <GridPane hgap="15" vgap="15"
                  style="-fx-border-color: #cccccc; -fx-border-radius: 5; -fx-padding: 15;">

            <columnConstraints>
                <ColumnConstraints percentWidth="20"/>
                <ColumnConstraints percentWidth="20"/>
                <ColumnConstraints percentWidth="20"/>
                <ColumnConstraints percentWidth="20"/>
                <ColumnConstraints percentWidth="20"/>
            </columnConstraints>

            <VBox GridPane.columnIndex="0"
                  GridPane.rowIndex="0"
                  spacing="5"
                  style="-fx-border-color: #e0e0e0; -fx-padding: 10; -fx-border-radius: 3;">
                <Label text="Total Produtos" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                <Label fx:id="lblTotalProdutos" text="0"
                       style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            </VBox>

            <VBox GridPane.columnIndex="1"
                  GridPane.rowIndex="0"
                  spacing="5"
                  style="-fx-border-color: #e0e0e0; -fx-padding: 10; -fx-border-radius: 3;">
                <Label text="Produtos Ativos" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                <Label fx:id="lblProdutosAtivos" text="0"
                       style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #4CAF50;"/>
            </VBox>

            <VBox GridPane.columnIndex="2"
                  GridPane.rowIndex="0"
                  spacing="5"
                  style="-fx-border-color: #e0e0e0; -fx-padding: 10; -fx-border-radius: 3;">
                <Label text="Total em Estoque" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                <Label fx:id="lblTotalEstoque" text="0"
                       style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #2196F3;"/>
            </VBox>

            <VBox GridPane.columnIndex="3"
                  GridPane.rowIndex="0"
                  spacing="5"
                  style="-fx-border-color: #e0e0e0; -fx-padding: 10; -fx-border-radius: 3;">
                <Label text="Estoque Baixo" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                <Label fx:id="lblProdutosBaixo" text="0"
                       style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #FF9800;"/>
            </VBox>

            <VBox GridPane.columnIndex="4"
                  GridPane.rowIndex="0"
                  spacing="5"
                  style="-fx-border-color: #e0e0e0; -fx-padding: 10; -fx-border-radius: 3;">
                <Label text="Valor Estimado" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                <Label fx:id="lblValorEstoque" text="R$ 0,00"
                       style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #9C27B0;"/>
            </VBox>

        </GridPane>

        <HBox spacing="10">
            <Button fx:id="btnCategorias" text="Categorias" prefWidth="150"/>
            <Button fx:id="btnProdutos" text="Produtos" prefWidth="150"/>
            <Button fx:id="btnMovimentacoes" text="Movimentações" prefWidth="150"/>
        </HBox>

        <Label text="Últimas Movimentações"
               style="-fx-font-size: 14; -fx-font-weight: bold;"/>

        <TableView fx:id="tableMovimentacoes" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colTipo" text="Tipo" prefWidth="80"/>
                <TableColumn fx:id="colQuantidade" text="Quantidade" prefWidth="100"/>
                <TableColumn fx:id="colObservacao" text="Observação" prefWidth="400"/>
                <TableColumn fx:id="colData" text="Data/Hora" prefWidth="200"/>
            </columns>
        </TableView>

    </VBox>

</AnchorPane>