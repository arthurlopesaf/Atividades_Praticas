<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.cadastro_clientes.TelaPrincipalController">

    <top>
        <VBox spacing="10">
            <padding>
                <Insets bottom="10" left="15" right="15" top="15" />
            </padding>

            <HBox spacing="10">
                <Label text="Pesquisar:" />
                <TextField fx:id="txtPesquisa" prefWidth="250" />

                <Button onAction="#btnPesquisar" text="Pesquisar" />

                <Button onAction="#btnMostrarTodos" text="Mostrar Todos" />
            </HBox>
        </VBox>
    </top>


    <center>
        <TableView fx:id="dgvClientes" prefHeight="300">

            <columns>

                <TableColumn fx:id="colId" prefWidth="50" text="ID" />

                <TableColumn fx:id="colNome" prefWidth="150" text="Nome" />

                <TableColumn fx:id="colCPF" prefWidth="120" text="CPF" />

                <TableColumn fx:id="colEmail" prefWidth="180" text="Email" />

                <TableColumn fx:id="colTelefone" prefWidth="120" text="Telefone" />

                <TableColumn fx:id="colCidade" prefWidth="120" text="Cidade" />

                <TableColumn fx:id="colAtivo" prefWidth="70" text="Ativo" />

            </columns>

        </TableView>
    </center>


    <bottom>
        <VBox spacing="15">

            <padding>
                <Insets bottom="15" left="15" right="15" top="15" />
            </padding>


            <GridPane hgap="10" vgap="10">

                <Label text="ID:" GridPane.columnIndex="0" GridPane.rowIndex="0" />

                <TextField fx:id="txtId" editable="false" GridPane.columnIndex="1" GridPane.rowIndex="0" />


                <Label text="Nome:" GridPane.columnIndex="0" GridPane.rowIndex="1" />

                <TextField fx:id="txtNome" GridPane.columnIndex="1" GridPane.rowIndex="1" />


                <Label text="CPF:" GridPane.columnIndex="0" GridPane.rowIndex="2" />

                <TextField fx:id="txtCPF" GridPane.columnIndex="1" GridPane.rowIndex="2" />


                <Label text="Email:" GridPane.columnIndex="0" GridPane.rowIndex="3" />

                <TextField fx:id="txtEmail" GridPane.columnIndex="1" GridPane.rowIndex="3" />


                <Label text="Telefone:" GridPane.columnIndex="0" GridPane.rowIndex="4" />

                <TextField fx:id="txtTelefone" GridPane.columnIndex="1" GridPane.rowIndex="4" />


                <Label text="Cidade:" GridPane.columnIndex="0" GridPane.rowIndex="5" />

                <TextField fx:id="txtCidade" GridPane.columnIndex="1" GridPane.rowIndex="5" />


                <CheckBox fx:id="chkAtivo" text="Cliente Ativo" GridPane.columnIndex="1" GridPane.rowIndex="6" />
            <columnConstraints>
               <ColumnConstraints />
               <ColumnConstraints />
            </columnConstraints>
            <rowConstraints>
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
               <RowConstraints />
            </rowConstraints>

            </GridPane>


            <HBox spacing="10">

                <Button onAction="#btnNovo" prefWidth="100" text="Novo" />

                <Button onAction="#btnSalvar" prefWidth="100" text="Salvar" />

                <Button onAction="#btnEditar" prefWidth="100" text="Editar" />

                <Button onAction="#btnExcluir" prefWidth="100" text="Excluir" />

                <Button onAction="#btnAtivarDesativar" prefWidth="130" text="Ativar/Desativar" />

                <Button onAction="#btnCancelar" prefWidth="100" text="Cancelar" />

            </HBox>

        </VBox>
    </bottom>

</BorderPane>
